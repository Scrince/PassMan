# macOS metadata
.DS_Store
._*

# Python caches and environments
__pycache__/
*.py[cod]
.venv/
.venv-*/

# Build and release outputs
build/
dist/
release/
# Top-level branding kit only (application icons live under src/assets/).
/assets/
*.log

# Local encrypted vault data
vault.dat
vault.dat.*

# Repo-local GPG release keyring: keep private/volatile material out of git.
.gnupg-release/

# Private keys and certificate bundles
*.key
*.pem
*.pfx
*.p12
